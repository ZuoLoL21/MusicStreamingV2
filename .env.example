# Postgres
POSTGRES_DB=music_streaming
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# User Database Crud
PROVIDER="ms-backend"
SUBJECT_NORMAL="general"
SUBJECT_REFRESH="refresh"
TIME_IN_M_NORMAL=10
TIME_IN_D_REFRESH=10
JWT_STORE_PATH="jwt/backend"
DB_CONNECTION_STRING="postgresql://postgres:postgres@localhost:5432/music_streaming"