# User Database
USER_CRUD_DB=music_streaming
USER_CRUD_USER=postgres
USER_CRUD_PASSWORD=postgres
USER_CRUD_PORT=5432
USER_CRUD_CONNECTION_STRING="postgresql://${USER_CRUD_USER}:${USER_CRUD_PASSWORD}@user-database:5432/${USER_CRUD_DB}"

# User Database Crud
USER_CRUD_JWT_PROVIDER_NAME="ms-backend"
JWT_STORE_PATH="jwt/backend"
JWT_SUBJECT_NORMAL="general"
JWT_TIME_IN_M_NORMAL=10
JWT_SUBJECT_REFRESH="refresh"
JWT_TIME_IN_D_REFRESH=10

# File Storage
FILE_STORAGE_DATA_LOCATION="/data"
FILE_STORAGE_LISTEN_ADDR="127.0.0.1:8000"

# Clickhouse
CLICKHOUSE_DB=default
CLICKHOUSE_USER="clickhouse"
CLICKHOUSE_PASSWORD="clickhouse"
CLICKHOUSE_PORT_TCP=9002
CLICKHOUSE_PORT_HTTP=8123
CLICKHOUSE_CONNECTION_STRING="clickhouse://${CLICKHOUSE_USER}:${CLICKHOUSE_PASSWORD}@clickhouse-database:9000/${CLICKHOUSE_DB}"

# Bandit Database
BANDIT_DB=bandit
BANDIT_USER="postgres"
BANDIT_PASSWORD="postgres"
BANDIT_PORT=5433
BANDIT_CONNECTION_STRING="postgresql://${BANDIT_USER}:${BANDIT_PASSWORD}@bandit-database:5432/${BANDIT_DB}"

# Bandit System Configuration
WAREHOUSE_BANDIT_DATA_TABLE="bandit_input_per_theme"
BANDIT_DATA_TABLE="bandit_data"
BANDIT_ALPHA=0.5
BANDIT_RIDGE_LAMBDA=1.0
SHERMAN_MORRISON_RECOMPUTE_INTERVAL=100
SHERMAN_MORRISON_DIVERGENCE_THRESHOLD=1e-6