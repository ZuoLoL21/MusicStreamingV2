# =============================================================================
# SECRETS - Copy to .env and set your values
# =============================================================================

# Database Passwords
USER_CRUD_PASSWORD=your_postgres_password_here
BANDIT_PASSWORD=your_bandit_password_here
CLICKHOUSE_PASSWORD=your_clickhouse_password_here

# MinIO Credentials
MINIO_ROOT_USER=your_minio_user_here
MINIO_ROOT_PASSWORD=your_minio_password_here

# Vault Token (use 'root' for dev mode)
VAULT_TOKEN=your_vault_token_here

# =============================================================================
# OPTIONAL - Environment-Specific Overrides
# =============================================================================

# Environment (default: development)
# ENVIRONMENT=development

# Host Port Mappings (defaults: 8080, 3000)
# GATEWAY_API_PORT=8080
# FRONTEND_PORT=3000
