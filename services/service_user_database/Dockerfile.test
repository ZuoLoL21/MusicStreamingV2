# Dockerfile for running integration tests
FROM golang:1.24-alpine

# Install dependencies
RUN apk add --no-cache git curl

# Set working directory
WORKDIR /app

# Copy go mod files from the service directory
COPY services/service_user_database/go.mod services/service_user_database/go.sum ./services/service_user_database/

# Copy libs (shared dependencies)
COPY libs/ ./libs/

# Set working directory to service
WORKDIR /app/services/service_user_database

# Download dependencies
RUN go mod download

# Copy all service code
COPY services/service_user_database/ ./

# Run tests
CMD ["go", "test", "-v", "-count=1", "./internal/client/..."]
