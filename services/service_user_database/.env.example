USER_CRUD_CONNECTION_STRING="postgresql://postgres:postgres@localhost:5432/music_streaming"
USER_CRUD_JWT_PROVIDER_NAME="ms-backend"
JWT_STORE_PATH="jwt/backend"

# JWT Expiration Times (optional - defaults from libs/consts/jwt_and_ctx.go)
# JWT_TIME_IN_M_NORMAL=10       # Default: 10 minutes (normal user JWT)
# JWT_TIME_IN_D_REFRESH=10      # Default: 10 days (refresh JWT)
# JWT_TIME_IN_M_SERVICE=2       # Default: 2 minutes (service JWT)

# Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN="root"

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=music-streaming
MINIO_USE_SSL=false

# Event Ingestion Service
EVENT_INGESTION_SERVICE_URL=http://localhost:8080
