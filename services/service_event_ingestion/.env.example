# =============================================================================
# REQUIRED - Secrets and Database Connection
# =============================================================================
CLICKHOUSE_CONNECTION_STRING=clickhouse://clickhouse:clickhouse@localhost:9000/default
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN="root"

# =============================================================================
# OPTIONAL - Override defaults if needed
# =============================================================================
# JWT_STORE_PATH=jwt/event-ingestion                  # Default: jwt/event-ingestion
# VAULT_APPLICATION_NAME=service_event_ingestion      # Default: service_event_ingestion
# VAULT_JWT_TIMEOUT_SECONDS=30                        # Default: 30 seconds
# ENVIRONMENT=development                             # Default: development
