# =============================================================================
# REQUIRED - Database Connection Strings (include secrets)
# =============================================================================
DB_CONNECTION_STRING_WAREHOUSE="clickhouse://clickhouse:clickhouse@localhost:8123/default"
DB_CONNECTION_STRING_PARAMS="postgresql://postgres:postgres@localhost:5433/bandit"

# =============================================================================
# OPTIONAL - Override defaults if needed
# =============================================================================
# Table Names
# WAREHOUSE_BANDIT_DATA_TABLE=bandit_input_per_theme  # Default: bandit_input_per_theme
# WAREHOUSE_THEME_CATALOG_TABLE=music_theme           # Default: music_theme
# BANDIT_DATA_TABLE=bandit_data                       # Default: bandit_data

# Bandit Hyperparameters
# BANDIT_ALPHA=0.5                                    # Default: 0.5
# BANDIT_RIDGE_LAMBDA=1.0                             # Default: 1.0
# SHERMAN_MORRISON_RECOMPUTE_INTERVAL=100             # Default: 100
# SHERMAN_MORRISON_DIVERGENCE_THRESHOLD=1e-6          # Default: 1e-6

# Retry Configuration
# MAX_RETRIES=3                                       # Default: 3
# BACKOFF_MS=100                                      # Default: 100