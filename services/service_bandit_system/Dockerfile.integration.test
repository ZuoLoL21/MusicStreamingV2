FROM python:3.11-slim

RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy service files
COPY services/service_bandit_system/pyproject.toml services/service_bandit_system/uv.lock ./
COPY services/service_bandit_system/src ./src
COPY services/service_bandit_system/tests ./tests
COPY services/service_bandit_system/main.py ./

RUN uv sync --extra dev

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["pytest", "tests/integration/", "--tb=short"]
