# =============================================================================
# REQUIRED - Secrets and Service URLs
# =============================================================================
POPULARITY_SERVICE_URL=http://localhost:8003
BANDIT_SERVICE_URL=http://localhost:8004
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN="root"

